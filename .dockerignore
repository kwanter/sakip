# Git
.git
.gitignore
.gitattributes

# Docker compose files (not needed in image context)
docker-compose.yml
docker-compose.*.yml
.docker

# Docs
README.md
LICENSE
*.md
docs/

# IDE / agent
.idea
.vscode
*.sublime-*
.DS_Store
.hive
.serena
.atlas
.claude
.trae
.auto-claude
.incident-evidence*
.sakip-incident*

# Node (built outside or multi-stage)
node_modules
npm-debug.log
yarn-error.log
public/hot
public/build

# Local env / secrets — NEVER bake into image
.env
.env.*
!.env.example
!.env.docker.example
.env.backup
.env.production
auth.json

# Tests
/tests
/phpunit.xml
.phpunit.result.cache
.phpunit.cache

# Vendor installed in build stage
/vendor

# Storage runtime
/storage/*.key
/storage/logs/*
/storage/framework/cache/*
/storage/framework/sessions/*
/storage/framework/views/*
!storage/.gitignore
!storage/app/.gitignore
!storage/app/public/.gitignore
!storage/app/private/.gitignore

# Database dumps / backups
**/backups/**
*.sql
*.sql.gz
*.tar.gz
*.dump
*.bak
docker/mysql/data/

# Cache
bootstrap/cache/*
!bootstrap/cache/.gitignore

# Temp / logs
*.tmp
*.swp
*.swo
*~
*.log

# Telescope / deploy
telescope
deploy.php
